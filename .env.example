# Sound It Backend Environment Variables

# App Settings
APP_NAME="Sound It API"
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/soundit

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (Generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# OTP Settings
OTP_EXPIRATION_MINUTES=5

# Twilio (SMS) - Get from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email) - Get from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@soundit.com

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Yoopay (Alternative Payment)
YOOPAY_API_KEY=your_yoopay_key
YOOPAY_SELLER_EMAIL=your@email.com
YOOPAY_PAYMENT_URL=https://yoopay.cn/tc/your_account

# WeChat (Mini Program)
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_wechat_api_key

# AWS S3 (File Uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=sound-it-uploads
AWS_REGION=us-east-1

# hearthis.at
HEARTHIS_API_KEY=your_hearthis_key
HEARTHIS_API_URL=https://hearthis.at/api/v1/
