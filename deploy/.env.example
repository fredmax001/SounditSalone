# ============================================================
# Sound It Platform - Production Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ============================================
# REQUIRED - Core Application Settings
# ============================================
APP_NAME="Sound It"
APP_ENV=production
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ============================================
# REQUIRED - Database
# ============================================
# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://username:password@localhost:5432/soundit

# Or SQLite (Not recommended for production)
# DATABASE_URL=sqlite:///./soundit_production.db

# ============================================
# REQUIRED - Frontend URL
# ============================================
FRONTEND_URL=https://sounditent.com

# ============================================
# EMAIL - SendGrid
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@sounditent.com
EMAIL_FROM_NAME="Sound It"

# ============================================
# SMS - Twilio
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# PAYMENTS - Stripe
# ============================================
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key

# ============================================
# SOCIAL AUTH - Google OAuth
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# FILE STORAGE - AWS S3
# ============================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=soundit-uploads
AWS_REGION=us-east-1

# Or local storage
UPLOAD_DIR=/var/www/soundit/uploads

# ============================================
# OPTIONAL - Monitoring & Analytics
# ============================================
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# OPTIONAL - Redis (for caching/sessions)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# OPTIONAL - 2FA
# ============================================
TOTP_ISSUER_NAME=SoundIt

# ============================================
# ALIBABA SMS (Alternative to Twilio for China)
# ============================================
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_SMS_SIGN_NAME=

# ============================================
# YooPay (Alternative payment for China)
# ============================================
YOOPAY_MERCHANT_ID=
YOOPAY_API_KEY=
YOOPAY_API_SECRET=
